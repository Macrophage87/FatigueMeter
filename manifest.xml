<?xml version="1.0"?>
<!--
  FatigueMeter — Connect IQ data field manifest.
  App type: datafield (on-ride single glance screen).

  Persistence (Toybox.Application.Storage): per-ride Session Results and the
  per-athlete calibration fit are carried between rides (white paper §8.3), so no
  separate widget is required.

  NOTE: the field does NOT maintain a cross-ride CTL/ATL/TSB residual ledger —
  it cannot do so honestly on-device, since it only sees the rides it is attached
  to. It computes per-ride load (TSS / TRIMP) and exports it via FIT developer
  fields; chronic accumulation belongs to the training-load platform.

  Target: Edge 1050 (primary) plus other power-capable Edge / Forerunner devices.
  Add device ids here as you test them; every listed product must expose a colour
  screen large enough for the single glance layout (white paper §8.1).
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        entry="FatigueMeterApp"
        id="7b2b3a25a76c407caa533adbcff1aa7a"
        launcherIcon="@Drawables.LauncherIcon"
        minSdkVersion="4.1.0"
        name="@Strings.AppName"
        type="datafield">

        <iq:products>
            <!-- Primary target -->
            <iq:product id="edge1050"/>
            <!-- Portable to other power-capable colour Edge units -->
            <iq:product id="edge1040"/>
            <iq:product id="edge840"/>
            <iq:product id="edge540"/>
            <iq:product id="edgeexplore2"/>
            <!-- Power-capable colour Forerunners -->
            <iq:product id="fr965"/>
            <iq:product id="fr955"/>
            <iq:product id="fenix7x"/>
        </iq:products>

        <iq:permissions>
            <!-- Ant: open a raw ANT+ channel to the HR strap to read beat-to-beat
                 RR intervals for DFA-α1. A data field cannot use the Sensor RR
                 listener, so (like the alphaHRV field) it reads the ANT+ HRM
                 broadcast directly. Requires an ANT+ strap (Polar H10 class). -->
            <iq:uses-permission id="Ant"/>
            <iq:uses-permission id="FitContributor"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
