<settings>
    <!-- Athlete profile -->
    <setting propertyKey="@Properties.ftp" title="@Strings.SetFtp">
        <settingConfig type="numeric" min="80" max="600"/>
    </setting>
    <setting propertyKey="@Properties.cp" title="@Strings.SetCp">
        <settingConfig type="numeric" min="80" max="600"/>
    </setting>
    <setting propertyKey="@Properties.wPrime" title="@Strings.SetWprime">
        <settingConfig type="numeric" min="3000" max="45000"/>
    </setting>
    <setting propertyKey="@Properties.hrMax" title="@Strings.SetHrMax">
        <settingConfig type="numeric" min="120" max="230"/>
    </setting>
    <setting propertyKey="@Properties.hrRest" title="@Strings.SetHrRest">
        <settingConfig type="numeric" min="30" max="90"/>
    </setting>
    <setting propertyKey="@Properties.sexFemale" title="@Strings.SetSex">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.ctlSeed" title="@Strings.SetCtlSeed">
        <settingConfig type="numeric" min="0" max="200"/>
    </setting>
    <setting propertyKey="@Properties.atlSeed" title="@Strings.SetAtlSeed">
        <settingConfig type="numeric" min="0" max="200"/>
    </setting>

    <!-- Acute filter (advanced; synthesis-grade — white paper §4.4) -->
    <setting propertyKey="@Properties.tauHr" title="@Strings.SetTauHr">
        <settingConfig type="numeric" min="5" max="120"/>
    </setting>
    <setting propertyKey="@Properties.tauA" title="@Strings.SetTauA">
        <settingConfig type="numeric" min="20" max="240"/>
    </setting>
    <setting propertyKey="@Properties.tauRec" title="@Strings.SetTauRec">
        <settingConfig type="numeric" min="120" max="3600"/>
    </setting>
    <setting propertyKey="@Properties.kappaI" title="@Strings.SetKappaI">
        <settingConfig type="numeric" min="0" max="0.02"/>
    </setting>
    <setting propertyKey="@Properties.kappaD" title="@Strings.SetKappaD">
        <settingConfig type="numeric" min="0" max="0.01"/>
    </setting>
    <setting propertyKey="@Properties.cF" title="@Strings.SetCf">
        <settingConfig type="numeric" min="0" max="0.1"/>
    </setting>
    <setting propertyKey="@Properties.fRef" title="@Strings.SetFref">
        <settingConfig type="numeric" min="4" max="30"/>
    </setting>

    <!-- Bands & thresholds (convention defaults) -->
    <setting propertyKey="@Properties.decoupOk" title="@Strings.SetDecoupOk">
        <settingConfig type="numeric" min="1" max="15"/>
    </setting>
    <setting propertyKey="@Properties.decoupCaution" title="@Strings.SetDecoupCaution">
        <settingConfig type="numeric" min="2" max="20"/>
    </setting>
    <setting propertyKey="@Properties.decoupHigh" title="@Strings.SetDecoupHigh">
        <settingConfig type="numeric" min="3" max="25"/>
    </setting>
    <setting propertyKey="@Properties.artifactGate" title="@Strings.SetArtifactGate">
        <settingConfig type="numeric" min="1" max="20"/>
    </setting>
    <setting propertyKey="@Properties.kjAnchor" title="@Strings.SetKjAnchor">
        <settingConfig type="numeric" min="800" max="4000"/>
    </setting>
    <setting propertyKey="@Properties.trimpFemaleCoeff" title="@Strings.SetTrimpFemaleCoeff">
        <settingConfig type="numeric" min="0.5" max="1.0"/>
    </setting>

    <!-- Options -->
    <setting propertyKey="@Properties.acwrEnabled" title="@Strings.SetAcwrEnabled">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.positivePilot" title="@Strings.SetPositivePilot">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.shipNumberOverride" title="@Strings.SetShipNumberOverride">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.unitsMetric" title="@Strings.SetUnitsMetric">
        <settingConfig type="boolean"/>
    </setting>
</settings>
